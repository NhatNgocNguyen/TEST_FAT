    "# create_model.py\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "import joblib\n",
    "import numpy as np\n",
    "\n",
    "X = np.array([[0],[1],[2],[3]])\n",
    "y = np.array([0,0,1,1])\n",
    "\n",
    "model = LogisticRegression().fit(X,y)\n",
    "\n",
    "joblib.dump(model, \"model.pkl\")"
   ]
  }
 ],
